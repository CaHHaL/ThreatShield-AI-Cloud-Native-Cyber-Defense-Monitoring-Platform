# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL credentials (used by both postgres container and backend)
POSTGRES_USER=threatshield
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=threatshield_db

# Async SQLAlchemy URL — must use asyncpg driver
DATABASE_URL=postgresql+asyncpg://threatshield:changeme_strong_password_here@postgres:5432/threatshield_db

# ─── Backend ──────────────────────────────────────────────────────────────────
SECRET_KEY=changeme_random_32char_secret_key_here
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── GeoIP ────────────────────────────────────────────────────────────────────
# Download GeoLite2-City.mmdb from https://www.maxmind.com/en/geolite2/signup
# Place it in backend/geoip/ before running, OR the service uses a fallback stub.
GEOIP_DB_PATH=/app/geoip/GeoLite2-City.mmdb

# ─── Honeypot Log Paths (inside backend container) ───────────────────────────
COWRIE_LOG_PATH=/cowrie-logs/cowrie.json
WEB_LOGIN_LOG_PATH=/cowrie-logs/web-login.json

# ─── Frontend (Vite env vars) ─────────────────────────────────────────────────
# For local Docker: use localhost
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# For AWS EC2: replace with your EC2 public IP
# VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8000
# VITE_WS_URL=ws://YOUR_EC2_PUBLIC_IP:8000
